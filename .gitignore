# Environment
.env
.env.backup
.env.production

# Dependencies
vendor/
node_modules/

# Storage
storage/logs/*
storage/framework/sessions/*
storage/framework/views/*
storage/framework/cache/*
storage/app/*
!storage/logs/.gitkeep
!storage/framework/sessions/.gitkeep
!storage/framework/views/.gitkeep
!storage/framework/cache/.gitkeep
!storage/app/.gitkeep

# Database — COMMITTED to repo so other developers have working database
# Only ignore backup files and SQLite journals (temporary runtime files)
database/*.sqlite-journal
database/*.sqlite-wal
database/*.sqlite-shm
database/*.sqlite.backup.*

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Build artifacts
coverage/
coverage/html/
coverage/*.xml
*.log

# Test artifacts
test-results/
playwright-report/
.phpunit.result.cache
.phpunit.cache/
