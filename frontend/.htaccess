# Content Security Policy for self-hosted assets
<IfModule mod_headers.c>
    Header unset Content-Security-Policy
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; connect-src 'self'; worker-src 'self' blob:; media-src 'self' data:; frame-ancestors 'self'; base-uri 'self'; form-action 'self';"
</IfModule>
